/**
 * Core Philosophy:
 * This ruleset implements a multi-tenant security model centered around Shops.
 * Each Shop is an isolated data silo controlled by a single owner (`shopOwnerId`).
 * The primary security mechanism is strict data ownership, ensuring shop owners can only
 * access and manage their own data (products, customers, bills).
 * A secondary, read-only access pattern is provided for authenticated customers,
 * allowing them to view their personal purchase history.
 *
 * Data Structure:
 * All application data is hierarchically organized under the `/shops/{shopId}` collection.
 * This top-level collection contains documents for each business, and all related data
 * (products, customers, bills, etc.) is stored in subcollections within that shop's document.
 * This structure naturally partitions data by tenant.
 *
 * Key Security Decisions:
 * - Default Deny: All operations are denied by default. Access is granted explicitly.
 * - No Global Listing: Listing all shops in the root collection is disallowed to protect tenant privacy.
 * - Owner-Centric Writes: All write operations (create, update, delete) on shop-related data
 *   are restricted to the designated shop owner.
 * - Customer Read-Only Access: Authenticated customers are granted read-only (`get`, `list`) access
 *   to their own bills and bill items, but they cannot list all bills in a shop.
 *
 * Denormalization for Authorization:
 * To ensure performant and simple security rules, this model relies heavily on denormalization.
 * - `shopOwnerId`: The UID of the shop owner is denormalized and stored on every single document
 *   within a shop's data tree. This allows for direct ownership checks without costly `get()` calls
 *   to parent documents.
 * - `customerAuthUid`: If a customer is authenticated, their UID is denormalized onto their
 *   associated `Bill` and `BillItem` documents. This enables a simple and fast rule to grant them
 *   read access to their purchase history.
 *
 * Structural Segregation:
 * Each data type (Products, Customers, Bills) is stored in its own dedicated subcollection
 * under a shop. This clear separation simplifies rule logic, as a single set of permissions can
 * be applied uniformly to all documents within a given collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the current request's authenticated user UID
     * matches the provided `uid`.
     */
    function isAuthOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    /**
     * Returns true if the document being accessed exists.
     * Used to protect against writes on non-existent documents.
     */
    function documentExists() {
      return resource != null;
    }

    /**
     * Checks if the authenticated user is the owner of the specified shop.
     * This requires a 'get' call to the parent shop document and should be used
     * to authorize collection-level 'list' operations.
     */
    function isShopOwner(shopId) {
      let shopDoc = get(/databases/$(database)/documents/shops/$(shopId));
      return isSignedIn() && shopDoc.data.shopOwnerId == request.auth.uid;
    }
    
    /**
     * Checks if the currently authenticated user is an Admin, by checking
     * for the existence of a document in the 'admins' collection.
     */
    function isAppAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }


    /**
     * Checks if the user is the owner based on the 'shopOwnerId' field
     * denormalized onto the document itself. This is the primary check
     * for document-level reads and writes.
     */
    function isDocumentOwner(docData) {
      return isAuthOwner(docData.shopOwnerId);
    }
    
    /**
     * Checks if the user is the customer associated with a bill or bill item,
     * based on the denormalized 'customerAuthUid' field.
     */
    function isDocumentCustomer(docData) {
      return isAuthOwner(docData.customerAuthUid);
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------
    
    /**
     * @description Public configuration data, readable by anyone.
     * @path /public/{docId}
     * @allow (get) Anyone can read public config (like activeShopId).
     * @allow (write) Only the shop owner can update the config.
     */
    match /public/{docId} {
        allow get: if true;
        allow write: if isShopOwner(request.resource.data.activeShopId);
    }
    
    /**
     * @description Controls access to the 'admins' collection for role management.
     * @path /admins/{userId}
     * @allow (get) A user can check their own admin status.
     * @allow (list, write) Only existing admins can list all admins or grant/revoke admin roles.
     * @principle Enables a role-based access control system managed within Firestore.
     */
    match /admins/{userId} {
      allow get: if isAuthOwner(userId);
      allow list, write: if isAppAdmin();
    }

    /**
     * @description Controls access to a Shop document, the root for all tenant data.
     * @path /shops/{shopId}
     * @allow (get) The owner of the shop can read their shop's details.
     * @allow (create) An authenticated user can create a new shop document for themselves.
     * @deny (list) No user, authenticated or not, can list all shops in the database.
     * @deny (update) A user cannot update a shop they do not own.
     * @principle Enforces strict document ownership and prevents cross-tenant data visibility.
     */
    match /shops/{shopId} {
      allow get: if isShopOwner(shopId);
      allow list: if false; // Disallow listing all shops
      allow create: if isSignedIn() && isAuthOwner(request.resource.data.shopOwnerId) && request.resource.data.id == shopId;
      allow update: if documentExists() && isShopOwner(shopId) && request.resource.data.shopOwnerId == resource.data.shopOwnerId;
      allow delete: if documentExists() && isShopOwner(shopId);
    }

    /**
     * @description Manages products within a specific shop.
     * @path /shops/{shopId}/products/{productId}
     * @allow (get, list) Anyone can view the products of a shop.
     * @allow (write) Only the shop owner can manage products.
     * @principle Public read access for inventory, owner-only writes.
     */
    match /shops/{shopId}/products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isShopOwner(shopId) && isAuthOwner(request.resource.data.shopOwnerId);
      allow update: if documentExists() && isShopOwner(shopId) && isDocumentOwner(resource.data);
      allow delete: if documentExists() && isShopOwner(shopId) && isDocumentOwner(resource.data);
    }

    /**
     * @description Manages customer records associated with a specific shop.
     * @path /shops/{shopId}/customers/{customerId}
     * @allow (create, list, get, update, delete) The shop owner can manage their customer records.
     * @principle Restricts all customer data management to the parent document's owner.
     */
    match /shops/{shopId}/customers/{customerId} {
      allow get: if isShopOwner(shopId);
      allow list: if isShopOwner(shopId);
      allow create: if isShopOwner(shopId);
      allow update: if documentExists() && isShopOwner(shopId);
      allow delete: if documentExists() && isShopOwner(shopId);
    }

    /**
     * @description Controls access to bills (invoices), allowing access for both shop owners and the relevant customer.
     * @path /shops/{shopId}/bills/{billId}
     * @allow (get) The shop owner OR the authenticated customer associated with the bill can read it.
     * @allow (list) Shop owner can list all bills. Customers can list THEIR bills.
     * @allow (create) The shop owner can create new bills.
     * @principle Implements a hybrid access model: full ownership for the shop owner and read-only access for a specific collaborator (the customer).
     */
    match /shops/{shopId}/bills/{billId} {
      allow get: if isShopOwner(shopId) || isDocumentCustomer(resource.data);
      allow list: if isShopOwner(shopId) || (isSignedIn() && request.query.where.size() > 0 && request.query.where[0][0] == 'customerAuthUid' && request.query.where[0][2] == request.auth.uid);
      allow create: if isShopOwner(shopId);
      allow update: if documentExists() && isShopOwner(shopId);
      allow delete: if documentExists() && isShopOwner(shopId);

      /**
       * @description Controls access to the line items of a bill.
       * @path /shops/{shopId}/bills/{billId}/billItems/{billItemId}
       * @allow (get, list) The shop owner OR the associated customer can view the bill's line items.
       * @allow (create) The shop owner can add items to their own bill.
       * @principle Inherits the hybrid access model from the parent bill, secured by denormalized IDs.
       */
      match /billItems/{billItemId} {
        allow get: if isShopOwner(shopId) || isDocumentCustomer(get(/databases/$(database)/documents/shops/$(shopId)/bills/$(billId)).data);
        allow list: if isShopOwner(shopId) || isDocumentCustomer(get(/databases/$(database)/documents/shops/$(shopId)/bills/$(billId)).data);
        allow create: if isShopOwner(shopId);
        allow update: if documentExists() && isShopOwner(shopId);
        allow delete: if documentExists() && isShopOwner(shopId);
      }
    }
    
    /**
     * @description Controls access to user profiles.
     * @path /users/{userId}
     * @allow (get) Any signed-in user can read any profile (profiles are public).
     * @allow (write) A user can only write to their own profile.
     */
    match /users/{userId} {
        allow get: if isSignedIn();
        allow write: if isAuthOwner(userId);
    }
  }
}
