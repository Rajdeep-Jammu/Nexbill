rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAppAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isShopOwner(shopId) {
      return isSignedIn() && (isAppAdmin() || (exists(/databases/$(database)/documents/shops/$(shopId)) && get(/databases/$(database)/documents/shops/$(shopId)).data.shopOwnerId == request.auth.uid));
    }

    match /public/{docId} {
      allow get: if true;
      allow write: if isAppAdmin();
    }

    match /admins/{userId} {
      allow get: if isAuthOwner(userId);
      allow list, write: if isAppAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow write: if isAuthOwner(userId);
    }

    match /sessions/{sessionId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn();
      allow list, delete: if isSignedIn() && (isAppAdmin() || isAuthOwner(resource.data.userId));
      allow update: if isSignedIn();
    }

    // Support Collection Group queries for Bills (used in Purchase History)
    // Rules for collection groups must be precisely matching the query filters for 'list' to work.
    match /{path=**}/bills/{billId} {
      // Allow list if the query is explicitly filtered by the user's UID
      allow list: if isSignedIn() && (
        request.query.filters.size() > 0 && 
        request.query.filters[0].field == "customerAuthUid" && 
        request.query.filters[0].value == request.auth.uid
      );
      
      // Allow individual document access if user is the customer or the shop owner
      allow get: if isSignedIn() && (
        resource.data.customerAuthUid == request.auth.uid || 
        isShopOwner(resource.data.shopId)
      );
    }

    match /shops/{shopId} {
      allow get: if true;
      allow create: if isSignedIn();
      allow update, delete: if isShopOwner(shopId);

      match /products/{productId} {
        allow get, list: if true;
        allow write: if isShopOwner(shopId);
      }

      match /bills/{billId} {
        // Standard path-based access
        allow read: if isSignedIn() && (isShopOwner(shopId) || resource.data.customerAuthUid == request.auth.uid);
        allow write: if isShopOwner(shopId);

        match /billItems/{billItemId} {
          // Allow reading items if the user owns the shop or is the customer of the parent bill
          // We use the parent bill's data for authorization to ensure consistency
          allow read: if isSignedIn() && (
            isShopOwner(shopId) || 
            get(/databases/$(database)/documents/shops/$(shopId)/bills/$(billId)).data.customerAuthUid == request.auth.uid
          );
          allow write: if isShopOwner(shopId);
        }
      }
    }
  }
}