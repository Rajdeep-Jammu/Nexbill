
{
  "entities": {
    "Shop": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Shop",
      "type": "object",
      "description": "Represents a business or shop using the inventory and billing system.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "currency": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "shopOwnerId": { "type": "string" },
        "secretCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "currency", "shopOwnerId", "secretCode", "createdAt", "updatedAt"]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents an individual product or service offered by the shop.",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "imageHint": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "shopId", "name", "price", "quantity", "createdAt", "updatedAt"]
    },
    "CheckoutSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Checkout Session",
      "type": "object",
      "description": "A temporary session representing a customer's intention to pay for specific items.",
      "properties": {
        "id": { "type": "string", "description": "The 4-digit numeric code." },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "userId": { "type": "string" },
        "shopId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "items", "total", "status", "shopId", "createdAt"]
    },
    "Bill": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Bill",
      "type": "object",
      "description": "Represents a single sales transaction.",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "shopOwnerId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerAuthUid": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "billDate": { "type": "string", "format": "date-time" },
        "subtotal": { "type": "number" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "itemCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "shopId", "invoiceNumber", "billDate", "totalAmount", "status", "createdAt", "updatedAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "points": { "type": "number" },
        "tier": { "type": "string" },
        "isVerified": { "type": "boolean" }
      },
      "required": ["uid", "email"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/shops/{shopId}",
        "definition": { "entityName": "Shop", "schema": { "$ref": "#/backend/entities/Shop" } }
      },
      {
        "path": "/shops/{shopId}/products/{productId}",
        "definition": { "entityName": "Product", "schema": { "$ref": "#/backend/entities/Product" } }
      },
      {
        "path": "/sessions/{sessionId}",
        "definition": { "entityName": "CheckoutSession", "schema": { "$ref": "#/backend/entities/CheckoutSession" } }
      },
      {
        "path": "/shops/{shopId}/bills/{billId}",
        "definition": { "entityName": "Bill", "schema": { "$ref": "#/backend/entities/Bill" } }
      },
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" } }
      }
    ]
  }
}
